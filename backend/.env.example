# ═══════════════════════════════════════════════════════════
# VSL - Vehículos Seguros Loja | Variables de Entorno
# ═══════════════════════════════════════════════════════════

# Servidor
NODE_ENV=development
PORT=3000

# Base de datos (PostgreSQL)
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/vsl_db?schema=public"

# JWT
JWT_SECRET="cambiar-por-clave-secreta-segura"
JWT_EXPIRES_IN="7d"

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# CORS
CORS_ORIGIN="http://localhost:8081"

# Logging
LOG_LEVEL="dev"
